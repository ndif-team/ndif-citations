# Semantic Scholar API key (optional — higher rate limits)
S2_API_KEY=your-s2-api-key-here

# LLM provider (OpenAI-compatible endpoint)
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-xxxxxxxxxxxx
LLM_MODEL=meta/llama-3.1-70b-instruct

# OpenAlex polite pool (provide your email for better rate limits)
OPENALEX_EMAIL=your-email@example.com

# GitHub API token (optional — upgrades rate limit from 60/hr to 5000/hr)
# Without this, activity fields (stars, forks, last_commit, etc.) may be null
# for repos beyond the first ~30 per run.
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# SerpAPI key (optional — enables Google Scholar discovery for papers that
# S2/OpenAlex reference parsers fail to link to the seed). One full discovery
# pass uses ~10-15 calls. Free tier = 250 calls/month (~20 full passes).
# Sign up at: https://serpapi.com/users/sign_up
SERPAPI_API_KEY=
